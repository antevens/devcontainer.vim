{
  "remoteEnv": {
    "EDITOR": "~/squashfs-root/AppRun",
    "PAGER": "sed -r 's/\\x1B\\[[0-9;]*[mGKH]//g' | ~/squashfs-root/AppRun -R -",
    "LESSCHARSET": "utf-8",
    "SHELL": "bash",
    "TERM": "xterm-256color",
    "HISTCONTROL": "erasedups",
    // If use WSLG
    // "DISPLAY": "${localEnv:DISPLAY}",
    // "WAYLAND_DISPLAY": "${localEnv:WAYLAND_DISPLAY}",
    // "XDG_RUNTIME_DIR": "${localEnv:XDG_RUNTIME_DIR}",
    // "PULSE_SERVER": "${localEnv:PULSE_SERVER}",
    // If use codex
    // "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
  },
  // If use claude code
  // "postCreateCommand": "npm install -g @anthropic-ai/claude-code",
  // If use codex
  // "postCreateCommand": "npm install -g @openai/codex",
  // If use Gemini
  // "postCreateCommand": "npm install -g @google/gemini-cli",
  // Since devcontainer/cli does not yet support forwardPorts,
  // copy the forwardPorts definition to appPort as needed.
  // * When listening on the container side, listen on 0.0.0.0 **instead of** 127.0.0.1.
  // "appPort": [
  // ],
  // When running on Linux, uncomment runArgs to enable connection from the container to the host.
  //"runArgs": [
  //  "--add-host=host.docker.internal:host-gateway"
  //],
  "mounts": [
    {
      "type": "bind",
      "source": "${localEnv:HOME}/.gitconfig",
      "target": "{{ remoteEnv:HOME }}/.gitconfig"
    },
    //{
    //  "type": "bind",
    //  "source": "${localEnv:HOME}/.ssh",
    //  "target": "{{ remoteEnv:HOME }}/.ssh"
    //},
    // If use host's bashrc
    {
      "type": "bind",
      "source": "${localEnv:HOME}/.bashrc",
      "target": "{{ remoteEnv:HOME }}/.bashrc"
    },
    {
      "type": "bind",
      "source": "${localEnv:HOME}/.bash_history",
      "target": "{{ remoteEnv:HOME }}/.bash_history"
    },
    // If use WSLG
    //{
    //  "type": "bind",
    //  "source": "/tmp/.X11-unix",
    //  "target": "/tmp/.X11-unix"
    //},
    //{
    //  "type": "bind",
    //  "source": "/mnt/wslg",
    //  "target": "/mnt/wslg"
    //},
    {
      "type": "dereferenced",
      "source": "${localEnv:HOME}/.vim",
      "target": "{{ remoteEnv:HOME }}/.vim"
    },
    // If use claude code
    {
      "type": "dereferenced",
      "source": "${localEnv:HOME}/.claude.json",
      "target": "{{ remoteEnv:HOME }}/.claude.json"
    },
    {
      "type": "dereferenced",
      "source": "${localEnv:HOME}/.claude",
      "target": "{{ remoteEnv:HOME }}/.claude"
    },
    // If use codex
    //{
    //  "type": "bind",
    //  "source": "${localEnv:HOME}/.codex",
    //  "target": "{{ remoteEnv:HOME }}/.codex"
    //},
    // If use gemini
    {
      "type": "bind",
      "source": "${localEnv:HOME}/.gemini",
      "target": "{{ remoteEnv:HOME }}/.gemini"
    },
    // If use github copilot
    //{
    //  "type": "bind",
    //  "source": "${localEnv:HOME}/.config/github-copilot",
    //  "target": "{{ remoteEnv:HOME }}/.config/github-copilot"
    //},
  ],
  // If a separate execution environment is required, such as denops,
  // or if there are tools you want to add later, uncomment the relevant lines below
  // or find and add the necessary features from https://containers.dev/features.
  //"features": {
  //  "ghcr.io/devcontainers-community/features/deno:1": {},
  //  "ghcr.io/devcontainers/features/node:1": {},
  //  "ghcr.io/devcontainers/features/python:1": {},
  //  "ghcr.io/devcontainers/features/ruby:1": {},
  //  "ghcr.io/devcontainers-extra/features/fzf:1": {},
  //  "ghcr.io/jungaretti/features/ripgrep:1": {},
  //  "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
  //  "ghcr.io/devcontainers/features/docker-in-docker:2": {},
  //  "ghcr.io/robbert229/devcontainer-features/postgresql-client:1": {},
  //}
}
